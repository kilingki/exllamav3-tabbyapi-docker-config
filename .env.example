# ExLlamaV3 + TabbyAPI Docker Config
# Copy this file to .env and edit the values below.

# Parent directory on the host that contains each EXL3 model folder.
# Compose mounts only ${MODELS_PATH}/${TABBY_MODEL_NAME} into the container.
MODELS_PATH=/path/to/your/exl3/models

# Folder name under MODELS_PATH (must exist as ${MODELS_PATH}/${TABBY_MODEL_NAME})
TABBY_MODEL_NAME=Your-Model-Folder-Name

# OpenAI-compatible API settings (used by test scripts)
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=local-dev-key
